              "",
              "const app = pm.collectionVariables.get(\"app\");",
              "const uri1 = pm.collectionVariables.get(\"uri1\");",
              "",
              "pm.test(\"Only uri1 returned\", function () {",
              "  pm.expect(arr.length).to.eql(1);",
              "  pm.expect(arr[0].app).to.eql(app);",
              "  pm.expect(arr[0].uri).to.eql(uri1);",
              "  pm.expect(Number(arr[0].hits)).to.eql(2);",
              "});"
