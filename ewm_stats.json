  "item": [
    {
      "name": "00 - Health + Init variables",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "  const runId = Date.now().toString();",
              "  pm.collectionVariables.set(\"runId\", runId);",
              "",
              "  pm.collectionVariables.set(\"app\", `ewm-main-postman-${runId}`);",
              "  pm.collectionVariables.set(\"uri1\", `/events/postman-${runId}-1`);",
              "  pm.collectionVariables.set(\"uri2\", `/events/postman-${runId}-2`);",
              "",
              "  // fixed timestamps in format: yyyy-MM-dd HH:mm:ss",
              "  pm.collectionVariables.set(\"t1\", \"2022-09-06 11:00:23\");",
              "  pm.collectionVariables.set(\"t2\", \"2022-09-06 11:00:24\");",
              "  pm.collectionVariables.set(\"t3\", \"2022-09-06 11:00:25\");",
              "",
              "  pm.collectionVariables.set(\"start\", \"2022-09-06 11:00:00\");",
              "  pm.collectionVariables.set(\"end\",   \"2022-09-06 12:00:00\");",
              "",
              "  // for negative case start > end",
              "  pm.collectionVariables.set(\"badStart\", \"2022-09-06 12:00:00\");",
              "  pm.collectionVariables.set(\"badEnd\",   \"2022-09-06 11:00:00\");",
              "",
              "pm.test(\"Health is UP\", function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql(\"UP\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        }
      },
      "response": []
    },
