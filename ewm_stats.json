    {
      "name": "04 - GET /stats (unique=false, all uris)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"OK\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const arr = pm.response.json();",
              "pm.expect(Array.isArray(arr)).to.be.true;",
              "",
              "const app = pm.collectionVariables.get(\"app\");",
              "const uri1 = pm.collectionVariables.get(\"uri1\");",
              "const uri2 = pm.collectionVariables.get(\"uri2\");",
              "",
              "function findStat(uri) {",
              "  return arr.find(x => x.app === app && x.uri === uri);",
              "}",
              "",
              "const s1 = findStat(uri1);",
              "const s2 = findStat(uri2);",
              "",
              "pm.test(\"Aggregated hits (non-unique)\", function () {",
              "  pm.expect(s1, \"stat for uri1 exists\").to.exist;",
              "  pm.expect(s2, \"stat for uri2 exists\").to.exist;",
              "  pm.expect(Number(s1.hits)).to.eql(2);",
              "  pm.expect(Number(s2.hits)).to.eql(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/stats?start={{start}}&end={{end}}&unique=false",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "stats"
