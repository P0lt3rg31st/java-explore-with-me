{
  "info": {
    "name": "EWM Main Service — API tests (fixed URLs)",
    "_postman_id": "51c1d5a5-4c8c-4d65-8f4c-5c0b1f1e6a12",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Smoke + negative API tests for Explore With Me main-service. URLs are strings to avoid Postman import issues."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userId", "value": "" },
    { "key": "requesterId", "value": "" },
    { "key": "catId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "requestId", "value": "" },
    { "key": "compId", "value": "" },
    { "key": "catName", "value": "" },
    { "key": "compTitle", "value": "" },
    { "key": "eventDate", "value": "" },
    { "key": "eventDate2", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const v = pm.collectionVariables.get('baseUrl');",
          "if (!v || String(v).trim().length===0) {",
          "  pm.collectionVariables.set('baseUrl','http://localhost:8080');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Setup (creates data for further tests)",
      "item": [
        {
          "name": "01. Admin: create user (initiator)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"initiator-{{$guid}}@example.com\",\n  \"name\": \"Initiator {{$timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.expect(j).to.have.property('id');",
                  "pm.expect(j.id).to.be.a('number');",
                  "pm.expect(j).to.have.property('email');",
                  "pm.expect(j).to.have.property('name');",
                  "pm.collectionVariables.set('userId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "02. Admin: create user (requester)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"requester-{{$guid}}@example.com\",\n  \"name\": \"Requester {{$timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.expect(j).to.have.property('id');",
                  "pm.collectionVariables.set('requesterId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "03. Admin: create category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{catName}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('catName', `Cat ${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.expect(j).to.have.property('id');",
                  "pm.expect(j.name).to.eql(pm.collectionVariables.get('catName'));",
                  "pm.collectionVariables.set('catId', j.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "04. Private: create event (initiator)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/{{userId}}/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"annotation\": \"This is a test annotation with enough length (>=20 chars).\",\n  \"category\": {{catId}},\n  \"description\": \"This is a test description with enough length (>=20 chars).\",\n  \"eventDate\": \"{{eventDate}}\",\n  \"location\": { \"lat\": 55.754167, \"lon\": 37.62 },\n  \"paid\": false,\n  \"participantLimit\": 2,\n  \"requestModeration\": true,\n  \"title\": \"Test event {{$timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function pad(n){ return (n<10?'0':'')+n; }",
                  "function fmt(d){ return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+' '+pad(d.getHours())+':'+pad(d.getMinutes())+':'+pad(d.getSeconds()); }",
                  "const dt = new Date(Date.now() + 3*60*60*1000);",
                  "pm.collectionVariables.set('eventDate', fmt(dt));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.expect(j).to.have.property('id');",
                  "pm.collectionVariables.set('eventId', j.id);"
                ]
              }
            }
          ]
        }
      ]
    },
